# ─── SUPABASE ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── STRIPE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform take rate (10% = 0.10)
STRIPE_PLATFORM_FEE_PERCENT=0.10

# ─── OPENAI (OCR) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── RESEND (EMAIL) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@cheetahreceipts.com
RESEND_FROM_NAME=Cheetah Receipts

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cheetahreceipts.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
ADMIN_EMAIL=admin@cheetahreceipts.com

# ─── AWS (for Amplify deployment) ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret

# ─── EXPO (mobile push notifications) ────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_token
